# ==============================================
# DOK1 Grader - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ==============================================
# REQUIRED - Application will not start without these
# ==============================================

# PostgreSQL database connection string
# Local Docker: postgresql://postgres:password@localhost:5432/dok1grader
# Neon Cloud:   postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/dok1grader

# OpenRouter API key for Claude AI integration
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==============================================
# OPTIONAL - Server Configuration
# ==============================================

# Server port (default: 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ==============================================
# OPTIONAL - Additional AI Services
# ==============================================

# Twitter/X API Bearer Token (for Twitter research features)
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# OpenAI API Key (alternative AI provider)
# AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here

# Custom OpenAI Base URL (if using a proxy or alternative endpoint)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Exa API Key (for Learning Stream Swarm web search)
# Get your key at: https://dashboard.exa.ai/api-keys
# EXA_API_KEY=your_exa_api_key_here

# ==============================================
# OPTIONAL - Learner Profile (Honcho)
# ==============================================

# Honcho API Key (persistent learner profiles across sessions)
# Get your key at: https://app.honcho.dev
# HONCHO_API_KEY=your_honcho_api_key_here

# Honcho Workspace ID (default: "brainlift-platform")
# HONCHO_WORKSPACE_ID=brainlift-platform
